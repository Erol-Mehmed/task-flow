@model List<ApplicationUser>

@{
  ViewData["Title"] = "Users";
}

<table class="table">
  <thead>
  <tr>
    <th>Email</th>
    <th>Actions</th>
  </tr>
  </thead>
  <tbody>
  @foreach (var user in Model)
  {
    <tr>
      <td>@user.Email</td>
      <td>
        <a asp-action="Edit" asp-route-id="@user.Id">Edit</a> |
        <a asp-action="Delete" asp-route-id="@user.Id">Delete</a>
      </td>
    </tr>
  }
  </tbody>
</table>
