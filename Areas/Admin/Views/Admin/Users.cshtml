@model List<ApplicationUser>

@{
  ViewData["Title"] = "Users";
  var currentUserId = ViewBag.CurrentUserId as string;
}

<h2 class="mb-4">Users</h2>

@if (TempData["ErrorMessage"] is string errorMessage)
{
  <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<div class="card shadow-sm app-card">
  <div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead>
      <tr>
        <th>Email</th>
        <th>Name</th>
        <th>Role</th>
        <th>Actions</th>
      </tr>
      </thead>
      <tbody>
      @foreach (var user in Model)
      {
        <tr>
          <td>@user.Email</td>
          <td>@user.FirstName @user.LastName</td>
          <td>@(ViewBag.UserRoles?[user.Id] ?? "-")</td>
          <td>
            <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">Edit</a>

            @if (user.Id == currentUserId)
            {
              <button type="button" class="btn btn-sm btn-secondary" disabled>Delete</button>
            }
            else
            {
              <button type="button"
                      class="btn btn-sm btn-danger"
                      data-user-id="@user.Id"
                      data-user-email="@user.Email"
                      onclick="adminUserDeleteConfirm.open(this.dataset.userId, this.dataset.userEmail)">
                Delete
              </button>
            }
          </td>
        </tr>
      }
      </tbody>
    </table>
  </div>
</div>

@await Html.PartialAsync("~/Views/Shared/Partials/_DeleteUserConfirmModal.cshtml")

