@model IEnumerable<task_flow.Models.TaskItem>

<div class="card shadow-sm app-card">
  <div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead>
      <tr>
        <th>Title</th>
        <th>Status</th>
      </tr>
      </thead>
      <tbody>
      @if (Model.Any())
      {
        @foreach (var t in Model)
        {
          <tr class="task-row"
              data-bs-toggle="modal"
              data-bs-target="#taskModal"
              data-task-id="@t.Id"
              data-task-title="@t.Title"
              data-task-description="@t.Description"
              onclick="openTask(this.dataset.taskTitle, this.dataset.taskDescription, this.dataset.taskId)">

            <td>
              <div class="d-flex align-items-center justify-content-between gap-2">
                <span>@t.Title</span>
                <a asp-controller="Task"
                   asp-action="Details"
                   asp-route-id="@t.Id"
                   class="btn btn-sm btn-outline-primary">
                  Details
                </a>
              </div>
            </td>
            <td>@t.Status</td>
          </tr>
        }
      }
      else
      {
        <tr>
          <td colspan="2" class="text-center text-muted py-4">No tasks found.</td>
        </tr>
      }
      </tbody>
    </table>
  </div>
</div>