<div class="modal fade" id="deleteUserModal" tabindex="-1" aria-labelledby="deleteUserModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="deleteUserModalLabel">Delete User</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body">
        Are you sure you want to delete "<strong id="deleteUserEmail"></strong>"?
      </div>

      <div class="modal-footer">
        <form id="deleteUserForm" asp-area="Admin" asp-controller="Admin" asp-action="Delete" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" id="deleteUserId" name="id" />
          <button type="submit" class="btn btn-danger">Delete</button>
        </form>

        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
      </div>
    </div>
  </div>
</div>

<script>
  window.adminUserDeleteConfirm = {
    open: function (userId, userEmail) {
      const userIdInput = document.getElementById("deleteUserId");
      const userEmailElement = document.getElementById("deleteUserEmail");
      const modalElement = document.getElementById("deleteUserModal");

      if (!userIdInput || !userEmailElement || !modalElement) {
        return;
      }

      userIdInput.value = userId || "";
      userEmailElement.innerText = userEmail || "this user";

      const modal = bootstrap.Modal.getOrCreateInstance(modalElement);
      modal.show();
    }
  };
</script>

