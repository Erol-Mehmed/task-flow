@model task_flow.Models.TaskItem

<h2>Delete Task</h2>

<div>
  <h4>Are you sure you want to delete this?</h4>

  <dl>
    <dt>Title</dt>
    <dd>@Model.Title</dd>

    <dt>Description</dt>
    <dd>@Model.Description</dd>
  </dl>

  <form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit">Delete</button>
  </form>
</div>