@model task_flow.Models.TaskDetailsViewModel

@{
  ViewData["Title"] = "Task Details";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
  <h2 class="mb-0">Task Details</h2>
  <a asp-action="Edit"
     asp-route-id="@Model.Task.Id"
     asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString"
     class="btn btn-warning">Edit</a>
</div>

<div class="card shadow-sm app-card">
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Title</dt>
      <dd class="col-sm-9">@Model.Task.Title</dd>

      <dt class="col-sm-3">Status</dt>
      <dd class="col-sm-9">
        <span class="badge bg-primary">@Model.Task.Status</span>
      </dd>

      <dt class="col-sm-3">Description</dt>
      <dd class="col-sm-9">
        @if (string.IsNullOrWhiteSpace(Model.Task.Description))
        {
          <span class="text-muted">No description provided.</span>
        }
        else
        {
          @Model.Task.Description
        }
      </dd>

      <dt class="col-sm-3">Workspace Id</dt>
      <dd class="col-sm-9">@(Model.Task.WorkspaceId?.ToString() ?? "-")</dd>
    </dl>
  </div>
</div>

<div class="card shadow-sm app-card mt-4">
  <div class="card-body">
    <h5 class="mb-3">Tags</h5>

    @if (!Model.Tags.Any())
    {
      <p class="text-muted mb-3">No tags yet.</p>
    }
    else
    {
      <div class="d-flex flex-wrap gap-2 mb-3">
        @foreach (var tag in Model.Tags)
        {
          <span class="badge bg-secondary">@tag.Name</span>
        }
      </div>
    }

    <form asp-controller="Tag" asp-action="Create" method="post" class="vstack gap-2">
      @Html.AntiForgeryToken()
      <input type="hidden" name="TaskId" value="@Model.Task.Id" />
      <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

      <div>
        <input name="Name" class="form-control" maxlength="50" required placeholder="Add a tag (e.g. backend)" />
      </div>

      <div>
        <button type="submit" class="btn btn-outline-primary">Add Tag</button>
      </div>
    </form>
  </div>
</div>

<div class="card shadow-sm app-card mt-4">
  <div class="card-body">
    <h5 class="mb-3">Add Comment</h5>

    <form asp-controller="Comment" asp-action="Create" method="post" class="vstack gap-3">
      @Html.AntiForgeryToken()
      <input type="hidden" name="TaskId" value="@Model.Task.Id" />
      <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

      <div>
        <textarea name="Content" class="form-control" rows="3" maxlength="1000" required
                  placeholder="Write a comment..."></textarea>
      </div>

      <div>
        <button type="submit" class="btn btn-primary">Post Comment</button>
      </div>
    </form>
  </div>
</div>

<div class="card shadow-sm app-card mt-4">
  <div class="card-body">
    <h5 class="mb-3">Comments (@Model.Comments.Count)</h5>

    @if (!Model.Comments.Any())
    {
      <p class="text-muted mb-0">No comments yet.</p>
    }
    else
    {
      <div class="vstack gap-3">
        @foreach (var comment in Model.Comments)
        {
          <div class="border rounded p-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <strong>@(comment.User?.Email ?? comment.UserId)</strong>
              <small class="text-muted">@comment.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
            </div>
            <p class="mb-0">@comment.Content</p>
          </div>
        }
      </div>
    }
  </div>
</div>