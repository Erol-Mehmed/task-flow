@model IEnumerable<task_flow.Models.TaskItem>

@{
  ViewData["Title"] = "Tasks";
}

<h2>Tasks</h2>

<p>
  <a asp-action="Create" class="btn btn-primary">Create New Task</a>
</p>

<table class="table">
  <thead>
  <tr>
    <th>Title</th>
    <th>Description</th>
    <th>Status</th>
    <th></th>
  </tr>
  </thead>
  <tbody>
  @foreach (var item in Model)
  {
    <tr>
      <td>@item.Title</td>
      <td>@item.Description</td>
      <td>@item.Status</td>
      <td>
        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>

        <button type="button"
                class="btn btn-sm btn-danger"
                data-task-id="@item.Id"
                data-task-title="@item.Title"
                onclick="taskDeleteConfirm.open(this.dataset.taskId, this.dataset.taskTitle)">
          Delete
        </button>
      </td>
    </tr>
  }
  </tbody>
</table>

@await Html.PartialAsync("~/Views/Shared/Partials/_DeleteTaskConfirmModal.cshtml")
