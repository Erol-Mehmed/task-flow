@model IEnumerable<task_flow.Models.Workspace.Workspace>

@{
  ViewData["Title"] = "Workspaces";
  var currentPage = (int)(ViewBag.CurrentPage ?? 1);
  var totalPages = (int)(ViewBag.TotalPages ?? 1);
}

<h2>Workspaces</h2>

<p>
  <a asp-action="Create" class="btn btn-primary">Create New Workspace</a>
</p>

<table class="table align-middle">
  <thead>
  <tr>
    <th>Name</th>
    <th>Owner</th>
    <th></th>
  </tr>
  </thead>
  <tbody>
  @foreach (var item in Model)
  {
    <tr>
      <td>
        <a asp-controller="Board"
           asp-action="Index"
           asp-route-workspaceId="@item.Id">
          @item.Name
        </a>
      </td>
      <td>@(item.User?.Email ?? "-")</td>
      <td>
        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>

        <button type="button"
                class="btn btn-sm btn-danger"
                data-workspace-id="@item.Id"
                data-workspace-name="@item.Name"
                onclick="workspaceDeleteConfirm.open(this.dataset.workspaceId, this.dataset.workspaceName)">
          Delete
        </button>
      </td>
    </tr>
  }
  </tbody>
</table>

@await Html.PartialAsync("~/Views/Shared/Partials/_DeleteWorkspaceConfirmModal.cshtml")

<nav class="mt-4 d-flex justify-content-center" aria-label="Workspace pagination">
  <ul class="pagination mb-0">
    @for (int i = 1; i <= totalPages; i++)
    {
      var pageNumber = i;
      <li class="page-item @(pageNumber == currentPage ? "active" : "")">
        <a class="page-link"
           asp-action="Index"
           asp-route-page="@pageNumber">
          @pageNumber
        </a>
      </li>
    }
  </ul>
</nav>
