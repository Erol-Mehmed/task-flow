@model IEnumerable<task_flow.Models.TaskItem>

@{
  ViewData["Title"] = "Home Page";
}

@* ----------------------- Unauthenticated User View ------------------ *@

@if (User?.Identity?.IsAuthenticated != true)
{
  <div class="text-center mt-5">
    <h1>Welcome to TaskFlow</h1>
    <p>Please login or register to manage your tasks.</p>

    <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Login">Login</a>
    <a class="btn btn-secondary" asp-area="Identity" asp-page="/Account/Register">Register</a>
  </div>

  return;
}

@* ---------------------- Authenticated User View ------------------ *@

<h2 class="mb-4">Task Board</h2>

<form method="get" class="row mb-4">
  <div class="col">
    <input name="search" class="form-control"
           value="@Context.Request.Query["search"]"
           placeholder="Search..."/>
  </div>

  <div class="col">
    <select name="status" class="form-control">
      <option value="">All</option>
      <option value="Todo" selected="@(Context.Request.Query["status"] == "Todo")">Todo</option>
      <option value="InProgress" selected="@(Context.Request.Query["status"] == "InProgress")">In Progress</option>
      <option value="Done" selected="@(Context.Request.Query["status"] == "Done")">Done</option>
    </select>
  </div>

  <div class="col">
    <button type="submit" class="btn btn-primary">Filter</button>
  </div>
</form>

<div class="row">
  <div class="col-md-4">
    <h5>Todo</h5>
    @foreach (var t in Model.Where(x => x.Status == "Todo"))
    {
      <div class="card mb-2 p-2">@t.Title</div>
    }
  </div>

  <div class="col-md-4">
    <h5>In Progress</h5>
    @foreach (var t in Model.Where(x => x.Status == "InProgress"))
    {
      <div class="card mb-2 p-2">@t.Title</div>
    }
  </div>

  <div class="col-md-4">
    <h5>Done</h5>
    @foreach (var t in Model.Where(x => x.Status == "Done"))
    {
      <div class="card mb-2 p-2">@t.Title</div>
    }
  </div>

  <nav class="mt-4">
    <ul class="pagination">
      @for (int i = 1; i <= (int)(ViewBag.TotalPages ?? 1); i++)
      {
        <li class="page-item @(i == (int)(ViewBag.CurrentPage ?? 1) ? "active" : "")">
          <a class="page-link"
             href="?page=@i&search=@Context.Request.Query["search"]&status=@Context.Request.Query["status"]">
            @i
          </a>
        </li>
      }
    </ul>
  </nav>
</div>
