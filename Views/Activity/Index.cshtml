@model IEnumerable<task_flow.Models.Activity.ActivityLog>

@{
  ViewData["Title"] = "Activity Log";
  var taskId = ViewBag.TaskId as int?;
  var currentPage = (int)(ViewBag.CurrentPage ?? 1);
  var totalPages = (int)(ViewBag.TotalPages ?? 1);
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
  <h2 class="mb-0">Activity Log</h2>
  @if (taskId.HasValue)
  {
    <a asp-controller="Task" asp-action="Details" asp-route-id="@taskId" class="btn btn-outline-secondary">Back to Task</a>
  }
</div>

<div class="card shadow-sm app-card">
  <div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead>
      <tr>
        <th>Time</th>
        <th>Action</th>
        <th>Task</th>
        <th>User</th>
        <th>Details</th>
      </tr>
      </thead>
      <tbody>
      @if (!Model.Any())
      {
        <tr>
          <td colspan="5" class="text-center text-muted py-4">No activity found.</td>
        </tr>
      }
      else
      {
        @foreach (var log in Model)
        {
          <tr>
            <td>@log.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
            <td>@log.Action</td>
            <td>
              @if (log.TaskItemId.HasValue)
              {
                <a asp-controller="Task" asp-action="Details" asp-route-id="@log.TaskItemId">#@log.TaskItemId</a>
              }
              else
              {
                <span class="text-muted">-</span>
              }
            </td>
            <td>@(log.User?.Email ?? log.UserId ?? "-")</td>
            <td>@(string.IsNullOrWhiteSpace(log.Details) ? "-" : log.Details)</td>
          </tr>
        }
      }
      </tbody>
    </table>
  </div>
</div>

<nav class="mt-4 d-flex justify-content-center" aria-label="Activity pagination">
  <ul class="pagination mb-0">
    @for (var i = 1; i <= totalPages; i++)
    {
      var pageNumber = i;
      <li class="page-item @(pageNumber == currentPage ? "active" : "")">
        <a class="page-link"
           asp-action="Index"
           asp-route-taskId="@taskId"
           asp-route-page="@pageNumber">@pageNumber</a>
      </li>
    }
  </ul>
</nav>

