@model IEnumerable<task_flow.Models.TaskItem>

@{
  ViewData["Title"] = "Board";
  var selectedStatus = Context.Request.Query["status"].ToString();
}

@if (User.Identity?.IsAuthenticated != true)
{
  <div class="card shadow-sm app-card mx-auto mt-5 board-page-hero-card">
    <div class="card-body text-center p-4 p-md-5">
      <h1 class="h2 mb-2">Welcome to TaskFlow</h1>
      <p class="text-muted mb-4">Please login or register to manage your tasks.</p>

      <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Login">Login</a>
      <a class="btn btn-outline-secondary" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </div>
  </div>

  return;
}

<section class="board-page">
  <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div>
      <h2 class="mb-0">
        Task Board
        @if (ViewBag.SelectedWorkspaceName != null)
        {
          <span class="text-muted fs-5">- @ViewBag.SelectedWorkspaceName</span>
        }
      </h2>

      @if (ViewBag.SelectedWorkspaceName != null)
      {
        <small class="text-muted">Showing tasks for the selected workspace</small>
      }
      else
      {
        <small class="text-muted">Click a row to view task details</small>
      }
    </div>

    @if (ViewBag.SelectedWorkspaceId != null)
    {
      <a asp-controller="Task"
         asp-action="Create"
         asp-route-workspaceId="@ViewBag.SelectedWorkspaceId"
         class="btn btn-success">
        Create Task
      </a>
    }
  </div>

  @if (ViewBag.SelectedWorkspaceId == null)
  {
    <div class="card shadow-sm app-card mb-4">
      <div class="card-body text-center py-4">
        <h5 class="mb-2">No workspace selected</h5>
        <p class="text-muted mb-3">Choose a workspace to see its board tasks.</p>
        <a asp-controller="Workspace" asp-action="Index" class="btn btn-primary">
          Go to Workspaces
        </a>
      </div>
    </div>

    return;
  }

  <form method="get" class="card shadow-sm app-card mb-4">
    @if (ViewBag.SelectedWorkspaceId != null)
    {
      <input type="hidden" name="workspaceId" value="@ViewBag.SelectedWorkspaceId"/>
    }

    <div class="card-body">
      <div class="row g-2 g-md-3 align-items-end">
        <div class="col-12 col-md-6">
          <label for="taskSearch" class="form-label mb-1">Search</label>
          <input id="taskSearch"
                 name="search"
                 class="form-control"
                 value="@Context.Request.Query["search"]"
                 placeholder="Search tasks by title..."/>
        </div>

        <div class="col-12 col-md-4">
          <label for="taskStatus" class="form-label mb-1">Status</label>
          <select id="taskStatus" name="status" class="form-select">
            <option value="">All</option>
            <option value="Todo" selected="@(selectedStatus == "Todo" ? "selected" : null)">Todo</option>
            <option value="InProgress" selected="@(selectedStatus == "InProgress" ? "selected" : null)">In Progress
            </option>
            <option value="Done" selected="@(selectedStatus == "Done" ? "selected" : null)">Done</option>
          </select>
        </div>

        <div class="col-12 col-md-2 d-grid">
          <button type="submit" class="btn btn-primary">Filter</button>
        </div>
      </div>
    </div>
  </form>

  @await Html.PartialAsync("~/Views/Shared/Partials/Board/_TaskTable.cshtml", Model)

  @await Html.PartialAsync("~/Views/Shared/Partials/Board/_TaskModal.cshtml")
  @await Html.PartialAsync("~/Views/Shared/Partials/_DeleteTaskConfirmModal.cshtml")

  <nav class="mt-4 d-flex justify-content-center" aria-label="Task pagination">
    <ul class="pagination mb-0">
      @for (int i = 1; i <= (int)(ViewBag.TotalPages ?? 1); i++)
      {
        var pageNumber = i;
        <li class="page-item @(pageNumber == (int)(ViewBag.CurrentPage ?? 1) ? "active" : "")">
          <a class="page-link"
             asp-controller="Board"
             asp-action="Index"
             asp-route-page="@pageNumber"
             asp-route-search="@Context.Request.Query["search"]"
             asp-route-status="@selectedStatus"
             asp-route-workspaceId="@ViewBag.SelectedWorkspaceId">
            @pageNumber
          </a>
        </li>
      }
    </ul>
  </nav>
</section>

<script>
  const editTaskBaseUrl = '@Url.Action("Edit", "Task")';
  let fullDescription = "";
  let isExpanded = false;
  const maxLength = 200;
  let currentTaskId = null;

  function openTask(title, description, id) {
    document.getElementById("modalTitle").innerText = title || "";

    fullDescription = description || "";
    isExpanded = false;
    currentTaskId = id;

    updateDescription();
  }

  function updateDescription() {
    const descEl = document.getElementById("modalDescription");
    const btn = document.getElementById("readMoreBtn");

    if (fullDescription.length <= maxLength) {
      descEl.innerText = fullDescription;
      btn.style.display = "none";
      return;
    }

    if (isExpanded) {
      descEl.innerText = fullDescription;
      btn.innerText = "Show less";
    } else {
      descEl.innerText = fullDescription.substring(0, maxLength) + "...";
      btn.innerText = "Read more";
    }

    btn.style.display = "inline";
  }

  function toggleDescription() {
    isExpanded = !isExpanded;
    updateDescription();
  }

  function editTask() {
    if (!currentTaskId) {
      return;
    }

    window.location.href = editTaskBaseUrl + "/" + currentTaskId;
  }

  function deleteTask() {
    if (!currentTaskId) {
      return;
    }

    const taskModalElement = document.getElementById("taskModal");
    const taskModal = bootstrap.Modal.getInstance(taskModalElement);
    if (taskModal) {
      taskModal.hide();
    }

    const currentTaskTitle = document.getElementById("modalTitle")?.innerText || "";
    if (window.taskDeleteConfirm && typeof window.taskDeleteConfirm.open === "function") {
      window.taskDeleteConfirm.open(currentTaskId, currentTaskTitle);
    }
  }
</script>