@model TaskItem

<form method="post">
  <input type="hidden" asp-for="Id" />
    
  <input asp-for="Title" />
  <input asp-for="Description" />

  <select asp-for="Status">
    <option>Todo</option>
    <option>InProgress</option>
    <option>Done</option>
  </select>

  <button type="submit">Save</button>
</form>