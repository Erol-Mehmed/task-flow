@model TaskItem

<form method="post">
  <input asp-for="Title" placeholder="Title" />
  <input asp-for="Description" placeholder="Description" />
    
  <select asp-for="Status">
    <option>Todo</option>
    <option>InProgress</option>
    <option>Done</option>
  </select>

  <button type="submit">Create</button>
</form>